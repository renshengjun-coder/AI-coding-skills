{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loop.dev/schemas/v1/ArtifactEnvelope.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "const": "loop.dev/v1"
    },
    "kind": {
      "const": "ArtifactEnvelope"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "revision",
        "createdAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageId",
        "phase",
        "artifactType",
        "content",
        "producer",
        "inputs",
        "outputs",
        "trace",
        "selfCheck"
      ],
      "properties": {
        "packageId": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "enum": [
            "requirements",
            "design",
            "test-planning",
            "implementation",
            "review",
            "validation",
            "release"
          ]
        },
        "artifactType": {
          "type": "string",
          "enum": [
            "requirement-spec",
            "design-document",
            "test-plan",
            "implementation-record",
            "review-report",
            "validation-report",
            "release-record"
          ]
        },
        "content": {
          "anyOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "path",
                "digest"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                },
                "digest": {
                  "type": "string",
                  "pattern": "^sha256:[0-9a-f]{64}$"
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "url",
                "digest"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                },
                "digest": {
                  "type": "string",
                  "pattern": "^sha256:[0-9a-f]{64}$"
                }
              }
            }
          ]
        },
        "producer": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "skill",
            "skillVersion",
            "runtime",
            "actor"
          ],
          "properties": {
            "skill": {
              "type": "string",
              "minLength": 1
            },
            "skillVersion": {
              "type": "string",
              "minLength": 1
            },
            "runtime": {
              "type": "string",
              "minLength": 1
            },
            "actor": {
              "type": "string",
              "minLength": 1
            },
            "modelId": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "id",
              "revision",
              "digest"
            ],
            "properties": {
              "kind": {
                "const": "ArtifactEnvelope"
              },
              "id": {
                "type": "string",
                "minLength": 1
              },
              "revision": {
                "type": "integer",
                "minimum": 1
              },
              "digest": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              }
            }
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "id",
              "revision",
              "digest"
            ],
            "properties": {
              "kind": {
                "const": "ArtifactEnvelope"
              },
              "id": {
                "type": "string",
                "minLength": 1
              },
              "revision": {
                "type": "integer",
                "minimum": 1
              },
              "digest": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              }
            }
          }
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "relation",
              "source",
              "target"
            ],
            "properties": {
              "relation": {
                "type": "string",
                "enum": [
                  "satisfies",
                  "derives-from",
                  "implements",
                  "verifies",
                  "reviews",
                  "validates",
                  "releases",
                  "supersedes"
                ]
              },
              "source": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "kind",
                  "id",
                  "revision",
                  "digest"
                ],
                "properties": {
                  "kind": {
                    "const": "ArtifactEnvelope"
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "revision": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "digest": {
                    "type": "string",
                    "pattern": "^sha256:[0-9a-f]{64}$"
                  }
                }
              },
              "target": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "kind",
                  "id",
                  "revision",
                  "digest"
                ],
                "properties": {
                  "kind": {
                    "const": "ArtifactEnvelope"
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "revision": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "digest": {
                    "type": "string",
                    "pattern": "^sha256:[0-9a-f]{64}$"
                  }
                }
              }
            }
          }
        },
        "selfCheck": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "result",
            "findingIds"
          ],
          "properties": {
            "result": {
              "type": "string",
              "enum": [
                "pass",
                "fail",
                "error"
              ]
            },
            "findingIds": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
