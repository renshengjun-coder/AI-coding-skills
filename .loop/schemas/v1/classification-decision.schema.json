{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loop.dev/schemas/v1/ClassificationDecision.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "const": "loop.dev/v1"
    },
    "kind": {
      "const": "ClassificationDecision"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "revision",
        "createdAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageId",
        "initialTier",
        "selectedTier",
        "classifier"
      ],
      "properties": {
        "packageId": {
          "type": "string",
          "minLength": 1
        },
        "initialTier": {
          "type": "string",
          "enum": [
            "routine",
            "standard",
            "high-risk"
          ]
        },
        "selectedTier": {
          "type": "string",
          "enum": [
            "routine",
            "standard",
            "high-risk"
          ]
        },
        "classifier": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "id",
            "version"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "rules",
                "automatic"
              ]
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "override": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "actor",
            "reason"
          ],
          "properties": {
            "actor": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
